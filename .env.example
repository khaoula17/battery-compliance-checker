# ---- App ----
NEXT_PUBLIC_APP_NAME="Battery Compliance Checker"
# Public site URL (used for SEO/OpenGraph metadata). e.g. https://yourdomain.com
NEXT_PUBLIC_SITE_URL=

# Feature flags — leave blank/false until the service is ready.
# When "true": pricing shows real checkout + monthly usage limits + PDF gating apply.
NEXT_PUBLIC_BILLING_ENABLED=
# When "true": shows the AI datasheet upload on the checker (needs an AI key too).
NEXT_PUBLIC_AI_ENABLED=

# Company info shown on Terms/Privacy pages
NEXT_PUBLIC_COMPANY_NAME=
NEXT_PUBLIC_CONTACT_EMAIL=
NEXT_PUBLIC_JURISDICTION=

# ---- Supabase (auth + DB) ----
# Without these, the app runs anonymously (checker works, no accounts/billing).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ---- Stripe (billing) ----
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Stripe Price IDs (create products/prices in Stripe, paste the price_... ids)
STRIPE_PRICE_PAYG=
STRIPE_PRICE_PRO=
STRIPE_PRICE_PRO_ANNUAL=
STRIPE_PRICE_WHITELABEL=
STRIPE_PRICE_WHITELABEL_ANNUAL=

# ---- AI SDS reader ---- (also set NEXT_PUBLIC_AI_ENABLED=true to show the upload)
# Gemini is FREE (aistudio.google.com) and reads PDFs + images — recommended to start.
GEMINI_API_KEY=
# Anthropic also supports PDF + images (paid). OpenAI works for images only (paid).
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# Optional model override (defaults: claude-haiku-4-5-20251001 / gpt-4o-mini)
AI_MODEL=

# ---- Email (Resend, transactional) ----
# Create a Resend account + verify a domain. Used for onboarding / reg-update notices.
RESEND_API_KEY=
EMAIL_FROM="ClearToShip <hello@yourdomain>"
# Where "new signup" notifications go (falls back to ADMIN_EMAILS)
NOTIFY_EMAIL=

# ---- Admin ----
# Comma-separated emails allowed into /admin
ADMIN_EMAILS=

# ---- REST API (fallback when Supabase is off) ----
API_INTERNAL_KEY=
